@model Game

@{
    ViewData["Title"] = "Game Details";
    ViewData["BodyClass"] = "page-mario page-games";
}

<h1>@Model.Title</h1>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-4">
                <h5>Developer</h5>
                <p>
                    @if (Model.Developer != null)
                    {
                        <a asp-controller="Developers" asp-action="Details" asp-route-id="@Model.Developer.Id">
                            @Model.Developer.Name
                        </a>
                    }
                </p>
            </div>
            <div class="col-md-4">
                <h5>Release Year</h5>
                <p>@Model.ReleaseYear</p>
            </div>
            <div class="col-md-4">
                <h5>Average Rating</h5>
                <p><span class="badge bg-success">@Model.AverageRating/100</span></p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <h5>Description</h5>
                <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description." : Model.Description)</p>
            </div>
        </div>

        @if (Model.Genres.Any())
        {
            <div class="row mb-3">
                <div class="col-12">
                    <h5>Genres</h5>
                    <div class="mario-detail-box">
                        <div class="mario-detail-box-body">
                            @foreach (var genre in Model.Genres)
                            {
                                <span class="badge bg-info me-1">
                                    <a asp-controller="Genres" asp-action="Details" asp-route-id="@genre.Id" style="color: white; text-decoration: none;">@genre.Name</a>
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        @if (Model.Platforms.Any())
        {
            <div class="row mb-3">
                <div class="col-12">
                    <h5>Platforms</h5>
                    <div class="mario-detail-box">
                        <div class="mario-detail-box-body">
                            @foreach (var platform in Model.Platforms)
                            {
                                <span class="badge bg-warning me-1">
                                    <a asp-controller="Platforms" asp-action="Details" asp-route-id="@platform.Id" style="color: white; text-decoration: none;">@platform.Name</a>
                                </span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <div class="mario-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm">Delete</a>
        </div>
    </div>
</div>

<div class="card mario-gallery-card-shell">
    <div class="card-body">
        <h2 class="mario-gallery-title">Game Gallery</h2>
        <div id="game-gallery" class="mario-gallery-region"></div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    <script type="text/javascript">
        (function () {
            const galleryRegion = "#game-gallery";
            const listUrl = "@Url.Action("Screenshots", "Games", new { id = Model.Id, mode = "slideshow" })";

            const loadGallery = () => {
                $(galleryRegion).load(listUrl, function () {
                    const slideshow = document.querySelector(".mario-slideshow");
                    if (!slideshow) return;

                    const thumbs = Array.from(slideshow.querySelectorAll(".mario-slideshow-thumb"));
                    const img = slideshow.querySelector(".mario-slideshow-frame img");
                    const name = slideshow.querySelector(".mario-slideshow-name");
                    const date = slideshow.querySelector(".mario-slideshow-date");
                    const user = slideshow.querySelector(".mario-slideshow-user-name");
                    const entryLink = slideshow.querySelector(".mario-slideshow-entry");
                    const prev = slideshow.querySelector(".mario-slideshow-prev");
                    const next = slideshow.querySelector(".mario-slideshow-next");

                    if (!img || !name || !date || thumbs.length === 0) return;

                    let index = thumbs.findIndex((thumb) => thumb.classList.contains("is-active"));
                    if (index < 0) index = 0;

                    const setActive = (newIndex) => {
                        index = (newIndex + thumbs.length) % thumbs.length;
                        const active = thumbs[index];
                        thumbs.forEach((thumb) => thumb.classList.remove("is-active"));
                        active.classList.add("is-active");
                        img.src = active.dataset.src;
                        img.alt = active.dataset.name || "Screenshot";
                        name.textContent = active.dataset.name || "";
                        date.textContent = active.dataset.date || "";
                        if (user) {
                            user.textContent = active.dataset.user || "";
                        }

                        if (entryLink) {
                            const entryUrl = active.dataset.entryUrl || "";
                            entryLink.setAttribute("href", entryUrl);
                        }
                    };

                    thumbs.forEach((thumb) => {
                        thumb.addEventListener("click", () => {
                            const thumbIndex = Number(thumb.dataset.index || 0);
                            setActive(thumbIndex);
                        });
                    });

                    prev?.addEventListener("click", () => setActive(index - 1));
                    next?.addEventListener("click", () => setActive(index + 1));
                });
            };

            $(function () {
                loadGallery();
            });
        })();
    </script>
}
