@model List<Game>

@{ var isAdmin = User.IsInRole("Admin"); }

<div class="table-responsive mario-table-wrap">
    <table class="table table-striped table-hover mario-table">
        <thead>
            <tr>
                <th>Title</th>
                <th>Release</th>
                <th>Developer</th>
                <th>Rating</th>
                <th>Genres</th>
                <th>Platforms</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="7" class="text-center">No games found.</td>
                </tr>
            }
            else
            {
                foreach (var game in Model)
                {
                    <tr>
                        <td>@game.Title</td>
                        <td>@game.ReleaseYear</td>
                        <td>@game.Developer?.Name</td>
                        <td><span class="badge bg-success">@game.AverageRating/100</span></td>
                        <td>@string.Join(", ", game.Genres.Select(g => g.Name))</td>
                        <td>@string.Join(", ", game.Platforms.Select(p => p.Name))</td>
                        <td class="mario-action-row">
                            <a asp-action="Details" asp-route-id="@game.Id" class="btn btn-sm">Details</a>
                            @if (isAdmin)
                            {
                                <a asp-action="Edit" asp-route-id="@game.Id" class="btn btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@game.Id" class="btn btn-sm">Delete</a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
