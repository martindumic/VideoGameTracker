@model List<Game>

@{
    ViewData["Title"] = "Games";
    ViewData["BodyClass"] = "page-mario page-games";
}

<section class="mario-stage mario-stage-prose">
    <div class="mario-panel mario-panel-wide mario-panel-split">
        <div class="mario-panel-header">
            <div>
                <h1>@ViewData["Title"]</h1>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-sm">New Game</a>
            }
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="login-alert home-alert login-alert-success" role="alert">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="login-alert home-alert login-alert-error" role="alert">@TempData["Error"]</div>
        }

        <div class="mario-panel-card">
            <div class="mario-search">
                <label for="game-search" class="form-label">Search games</label>
                <div class="mario-search-row">
                    <input id="game-search" type="text" class="form-control mario-input js-list-search" placeholder="Search title, developer, genres..." data-search-url="@Url.Action("Search", "Games")" data-target="#game-list" />
                    <span class="mario-search-spinner" aria-hidden="true"></span>
                </div>
            </div>

            <div id="game-list" class="mario-list-region">
                @await Html.PartialAsync("_GameTable", Model)
            </div>
        </div>
    </div>
</section>
