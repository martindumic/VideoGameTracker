@model Game

@{
    ViewData["Title"] = "Delete Game";
    ViewData["BodyClass"] = "page-mario page-games";
    var deleteBlocked = ViewData["DeleteBlocked"] as bool? ?? false;
    var deleteReason = ViewData["DeleteReason"] as string;
}

<h1>@ViewData["Title"]</h1>

<div class="card">
    <div class="card-body">
        <div class="mario-delete-summary">
            <p><strong>Title:</strong> @Model.Title</p>
            <p><strong>Developer:</strong> @Model.Developer?.Name</p>
            <p><strong>Release Year:</strong> @Model.ReleaseYear</p>
            <p><strong>Rating:</strong> @Model.AverageRating/100</p>
        </div>

        @if (deleteBlocked)
        {
            <div class="login-alert home-alert login-alert-error" role="alert">@deleteReason</div>
        }
        else
        {
            <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mario-actions">
                <button type="submit" class="btn btn-sm">Delete Game</button>
            </form>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
