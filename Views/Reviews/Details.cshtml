@model Review

@{
    ViewData["Title"] = "Review Details";
}

<h1>Review</h1>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <h5>Game</h5>
                <p>
                    @if (Model.Game != null)
                    {
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.Game.Id">
                            @Model.Game.Title
                        </a>
                    }
                </p>
            </div>
            <div class="col-md-6">
                <h5>User</h5>
                <p>
                    @if (Model.User != null)
                    {
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.User.Id">
                            @Model.User.Username
                        </a>
                    }
                </p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <h5>Score</h5>
                <p><span class="badge bg-warning">@Model.Score/100</span></p>
            </div>
            <div class="col-md-6">
                <h5>Created At</h5>
                <p>@Model.CreatedAt.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <h5>Comment</h5>
                <p>@Model.Comment</p>
            </div>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Reviews" asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
