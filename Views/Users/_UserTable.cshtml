@model List<AppUser>

<div class="table-responsive mario-table-wrap">
    <table class="table table-striped table-hover mario-table">
        <thead>
            <tr>
                <th>Username</th>
                <th>Email</th>
                <th>Registered</th>
                <th>Entries</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-center">No users found.</td>
                </tr>
            }
            else
            {
                foreach (var user in Model)
                {
                    <tr>
                        <td>@user.UserName</td>
                        <td>@user.Email</td>
                        <td>@user.RegisteredAt.ToString("d")</td>
                        <td><span class="badge bg-info">@user.GameEntries.Count</span></td>
                        <td class="mario-action-row">
                            <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
