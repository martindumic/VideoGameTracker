@model List<User>

@{
    ViewData["Title"] = "Users";
}

<h1>@ViewData["Title"]</h1>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Username</th>
                <th>Email</th>
                <th>Registered At</th>
                <th>Game Entries</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.Id</td>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@user.RegisteredAt.ToString("dd/MM/yyyy")</td>
                    <td><span class="badge bg-info">@user.GameEntries.Count</span></td>
                    <td>
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
