@model List<AppUser>

@{
    ViewData["Title"] = "Users";
    ViewData["BodyClass"] = "page-mario page-users";
}

<section class="mario-stage mario-stage-prose">
    <div class="mario-panel mario-panel-wide mario-panel-split">
        <div class="mario-panel-header">
            <div>
                <h1>@ViewData["Title"]</h1>
            </div>
            <a asp-action="Create" class="btn btn-sm">New User</a>
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="login-alert home-alert login-alert-success" role="alert">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="login-alert home-alert login-alert-error" role="alert">@TempData["Error"]</div>
        }

        <div class="mario-panel-card">
            <div class="mario-search">
                <label for="user-search" class="form-label">Search users</label>
                <div class="mario-search-row">
                    <input id="user-search" type="text" class="form-control mario-input js-list-search" placeholder="Search username or email..." data-search-url="@Url.Action("Search", "Users")" data-target="#user-list" />
                    <span class="mario-search-spinner" aria-hidden="true"></span>
                </div>
            </div>

            <div id="user-list" class="mario-list-region">
                @await Html.PartialAsync("_UserTable", Model)
            </div>
        </div>
    </div>
</section>
