@model User

@{
    ViewData["Title"] = "User Details";
}

<h1>@Model.Username</h1>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <h5>Email</h5>
                <p>@Model.Email</p>
            </div>
            <div class="col-md-6">
                <h5>Registered At</h5>
                <p>@Model.RegisteredAt.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        @if (Model.GameEntries.Any())
        {
            <div class="row">
                <div class="col-12">
                    <h5>Game Entries (@Model.GameEntries.Count)</h5>
                    <ul class="list-group">
                        @foreach (var entry in Model.GameEntries)
                        {
                            <li class="list-group-item">
                                <div>
                                    <strong>
                                        <a asp-controller="Games" asp-action="Details" asp-route-id="@entry.Game?.Id">
                                            @entry.Game?.Title
                                        </a>
                                    </strong>
                                    <span class="badge bg-secondary ms-2">@entry.Status</span>
                                </div>
                                <small>@entry.HoursPlayed hours played - Added: @entry.CreatedAt.ToString("dd/MM/yyyy")</small>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="Users" asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
