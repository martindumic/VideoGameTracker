@model AppUser

@{
    ViewData["Title"] = "User Details";
    ViewData["BodyClass"] = "page-mario page-users";
}

<h1>@Model.UserName</h1>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <h5>Email</h5>
                <p>@Model.Email</p>
            </div>
            <div class="col-md-6">
                <h5>Registered At</h5>
                <p>@Model.RegisteredAt.ToString("d")</p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <h5>OIB</h5>
                <p>@Model.OIB</p>
            </div>
            <div class="col-md-6">
                <h5>JMBG</h5>
                <p>@Model.JMBG</p>
            </div>
        </div>

        @if (Model.GameEntries.Any())
        {
            <div class="row">
                <div class="col-12">
                    <h5>Game Entries (@Model.GameEntries.Count)</h5>
                    <div class="mario-detail-box">
                        <ul class="list-group mb-0">
                            @foreach (var entry in Model.GameEntries)
                            {
                                <li class="list-group-item">
                                    <div>
                                        <strong>
                                            <a asp-controller="Games" asp-action="Details" asp-route-id="@entry.Game?.Id">@entry.Game?.Title</a>
                                        </strong>
                                        <span class="badge bg-secondary ms-2">@entry.Status</span>
                                    </div>
                                    <small>@entry.HoursPlayed hours played - Added: @entry.CreatedAt.ToString("d")</small>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }

        <div class="mario-actions mt-3">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm">Delete</a>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
