@{
    ViewData["Title"] = "Login";
    ViewData["BodyClass"] = "page-mario page-login";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="login-title-stage">
    <div class="login-title-lockup">
        <img src="~/images/smb_logo.png" alt="Super Mario Bros inspired logo" class="login-logo-image" />
        <h1 class="login-app-title">VideoGameTracker</h1>
        <p class="login-subtitle">SIGN IN TO CONTINUE</p>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        @foreach (var modelState in ViewData.ModelState.Values)
        {
            @foreach (var error in modelState.Errors)
            {
                <div class="login-alert" role="alert">
                    @error.ErrorMessage
                </div>
            }
        }
    }

    <form method="post" asp-action="Index" asp-controller="Login" class="login-title-form">
        <div class="login-field">
            <label for="email" class="login-field-label">EMAIL</label>
            <input type="email" class="login-title-input" id="email" name="email" placeholder="gamer@email.com" required>
        </div>

        <div class="login-field">
            <label for="password" class="login-field-label">PASSWORD</label>
            <input type="password" class="login-title-input" id="password" name="password" placeholder="********" required>
        </div>

        <button type="submit" class="login-title-button">
            <span class="login-title-bullet" aria-hidden="true">●</span>
            <span>SIGN IN</span>
        </button>
    </form>

    <div class="login-hint">
        Demo credentials: Email: gamerpro@email.com | Password: hashed_password_1
    </div>
</section>
