@model List<Platform>

@{ var isAdmin = User.IsInRole("Admin"); }

<div class="table-responsive mario-table-wrap">
    <table class="table table-striped table-hover mario-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Games</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="4" class="text-center">No platforms found.</td>
                </tr>
            }
            else
            {
                foreach (var platform in Model)
                {
                    <tr>
                        <td>@platform.Name</td>
                        <td>@platform.Type</td>
                        <td><span class="badge bg-info">@platform.Games.Count</span></td>
                        <td class="mario-action-row">
                            <a asp-action="Details" asp-route-id="@platform.Id" class="btn btn-sm">Details</a>
                            @if (isAdmin)
                            {
                                <a asp-action="Edit" asp-route-id="@platform.Id" class="btn btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@platform.Id" class="btn btn-sm">Delete</a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
