@model List<Genre>

<div class="table-responsive mario-table-wrap">
    <table class="table table-striped table-hover mario-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Games</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="3" class="text-center">No genres found.</td>
                </tr>
            }
            else
            {
                foreach (var genre in Model)
                {
                    <tr>
                        <td>@genre.Name</td>
                        <td><span class="badge bg-info">@genre.Games.Count</span></td>
                        <td class="mario-action-row">
                            <a asp-action="Details" asp-route-id="@genre.Id" class="btn btn-sm">Details</a>
                            <a asp-action="Edit" asp-route-id="@genre.Id" class="btn btn-sm">Edit</a>
                            <a asp-action="Delete" asp-route-id="@genre.Id" class="btn btn-sm">Delete</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
