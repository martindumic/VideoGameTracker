@model List<Genre>

@{
    ViewData["Title"] = "Genres";
}

<h1>@ViewData["Title"]</h1>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Games Count</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var genre in Model)
            {
                <tr>
                    <td>@genre.Id</td>
                    <td>@genre.Name</td>
                    <td><span class="badge bg-info">@genre.Games.Count</span></td>
                    <td>
                        <a asp-controller="Genres" asp-action="Details" asp-route-id="@genre.Id" class="btn btn-sm btn-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
