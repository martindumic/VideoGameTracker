@model GenreFormViewModel

@{
    ViewData["Title"] = "Create Genre";
    ViewData["BodyClass"] = "page-mario page-genres";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="login-alert home-alert login-alert-success" role="alert">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="login-alert home-alert login-alert-error" role="alert">@TempData["Error"]</div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="Create" method="post" class="mario-form">
            @await Html.PartialAsync("_GenreForm", Model)
            <div class="mario-actions">
                <button type="submit" class="btn btn-sm">Create Genre</button>
            </div>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
