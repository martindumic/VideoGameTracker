@model Developer

@{
    ViewData["Title"] = "Developer Details";
    ViewData["BodyClass"] = "page-mario page-developers";
}

<h1>@Model.Name</h1>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <h5>Country</h5>
                <p>@Model.Country</p>
            </div>
            <div class="col-md-6">
                <h5>Founded</h5>
                <p>@Model.Founded.ToString("d")</p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <h5>Description</h5>
                <p>@(string.IsNullOrWhiteSpace(Model.Description) ? "No description." : Model.Description)</p>
            </div>
        </div>

        @if (Model.Games.Any())
        {
            <div class="row">
                <div class="col-12">
                    <h5>Games</h5>
                    <div class="mario-detail-box">
                        <ul class="list-group mb-0">
                            @foreach (var game in Model.Games)
                            {
                                <li class="list-group-item">
                                    <a asp-controller="Games" asp-action="Details" asp-route-id="@game.Id">@game.Title</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </div>
        }

        <div class="mario-actions mt-3">
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm">Delete</a>
            }
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
