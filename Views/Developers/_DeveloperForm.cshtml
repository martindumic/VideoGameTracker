@model DeveloperFormViewModel

<div>
    <div asp-validation-summary="ModelOnly" class="mario-validation-summary"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Name</label>
        <input asp-for="Name" class="form-control mario-input" />
        <span asp-validation-for="Name" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Country" class="form-label">Country</label>
        <input asp-for="Country" class="form-control mario-input" />
        <span asp-validation-for="Country" class="text-danger"></span>
    </div>

    @await Html.PartialAsync("_DateTimePicker", new DateTimePickerViewModel
    {
        Label = "Founded",
        InputName = nameof(Model.Founded),
        InputId = "developer-founded",
        Value = Model.Founded,
        Placeholder = "dd.MM.yyyy",
        IsRequired = true
    })
    <span asp-validation-for="Founded" class="text-danger"></span>

    <div class="mb-3">
        <label asp-for="Description" class="form-label">Description</label>
        <textarea asp-for="Description" rows="4" class="form-control mario-input" placeholder="Studio bio..."></textarea>
        <span asp-validation-for="Description" class="text-danger"></span>
    </div>

    <input type="hidden" asp-for="Id" />
</div>
