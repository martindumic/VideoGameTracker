@model List<Developer>

@{ var isAdmin = User.IsInRole("Admin"); }

<div class="table-responsive mario-table-wrap">
    <table class="table table-striped table-hover mario-table">
        <thead>
            <tr>
                <th>Name</th>
                <th>Country</th>
                <th>Founded</th>
                <th>Games</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count == 0)
            {
                <tr>
                    <td colspan="5" class="text-center">No developers found.</td>
                </tr>
            }
            else
            {
                foreach (var developer in Model)
                {
                    <tr>
                        <td>@developer.Name</td>
                        <td>@developer.Country</td>
                        <td>@developer.Founded.ToString("d")</td>
                        <td><span class="badge bg-info">@developer.Games.Count</span></td>
                        <td class="mario-action-row">
                            <a asp-action="Details" asp-route-id="@developer.Id" class="btn btn-sm">Details</a>
                            @if (isAdmin)
                            {
                                <a asp-action="Edit" asp-route-id="@developer.Id" class="btn btn-sm">Edit</a>
                                <a asp-action="Delete" asp-route-id="@developer.Id" class="btn btn-sm">Delete</a>
                            }
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
