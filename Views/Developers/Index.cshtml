@model List<Developer>

@{
    ViewData["Title"] = "Developers";
}

<h1>@ViewData["Title"]</h1>

<div class="table-responsive">
    <table class="table table-striped table-hover">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Name</th>
                <th>Country</th>
                <th>Founded</th>
                <th>Games Count</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var developer in Model)
            {
                <tr>
                    <td>@developer.Id</td>
                    <td>@developer.Name</td>
                    <td>@developer.Country</td>
                    <td>@developer.Founded.Year</td>
                    <td><span class="badge bg-info">@developer.Games.Count</span></td>
                    <td>
                        <a asp-controller="Developers" asp-action="Details" asp-route-id="@developer.Id" class="btn btn-sm btn-primary">Details</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
