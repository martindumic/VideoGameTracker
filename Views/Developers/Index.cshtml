@model List<Developer>

@{
    ViewData["Title"] = "Developers";
    ViewData["BodyClass"] = "page-mario page-developers";
}

<section class="mario-stage mario-stage-prose">
    <div class="mario-panel mario-panel-wide mario-panel-split">
        <div class="mario-panel-header">
            <div>
                <h1>@ViewData["Title"]</h1>
            </div>
            @if (User.IsInRole("Admin"))
            {
                <a asp-action="Create" class="btn btn-sm">New Developer</a>
            }
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="login-alert home-alert login-alert-success" role="alert">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="login-alert home-alert login-alert-error" role="alert">@TempData["Error"]</div>
        }

        <div class="mario-panel-card">
            <div class="mario-search">
                <label for="developer-search" class="form-label">Search developers</label>
                <div class="mario-search-row">
                    <input id="developer-search" type="text" class="form-control mario-input js-list-search" placeholder="Search name, country, description..." data-search-url="@Url.Action("Search", "Developers")" data-target="#developer-list" />
                    <span class="mario-search-spinner" aria-hidden="true"></span>
                </div>
            </div>

            <div id="developer-list" class="mario-list-region">
                @await Html.PartialAsync("_DeveloperTable", Model)
            </div>
        </div>
    </div>
</section>
