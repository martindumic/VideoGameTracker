@using Microsoft.AspNetCore.Identity
@using VideoGameTracker.Models
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager

@if (SignInManager.IsSignedIn(User))
{
    <form class="d-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
        <button type="submit" class="smb-login-nav-link btn btn-link p-0">Logout</button>
    </form>
}
else
{
    <a class="smb-login-nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
    <a class="smb-login-nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
}
