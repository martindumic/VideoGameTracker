<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VideoGameTracker</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.css" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/VideoGameTracker.styles.css" asp-append-version="true" />
</head>
@{ var isLoginPage = (ViewData["BodyClass"]?.ToString() ?? string.Empty).Contains("page-login"); }
<body class="@(ViewData["BodyClass"]?.ToString() ?? "page-mario")">
    <header class="smb-login-header">
        <nav class="smb-login-nav" aria-label="Primary">
            <div class="smb-login-nav-inner">
                <a class="smb-login-nav-link" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                @if (Context.Session.GetInt32("UserId") != null)
                {
                    <a class="smb-login-nav-link" asp-area="" asp-controller="Developers" asp-action="Index">Developers</a>
                    <a class="smb-login-nav-link" asp-area="" asp-controller="Games" asp-action="Index">Games</a>
                    <a class="smb-login-nav-link" asp-area="" asp-controller="Genres" asp-action="Index">Genres</a>
                    <a class="smb-login-nav-link" asp-area="" asp-controller="Platforms" asp-action="Index">Platforms</a>
                    <a class="smb-login-nav-link" asp-area="" asp-controller="Users" asp-action="Index">Users</a>
                    <a class="smb-login-nav-link" asp-area="" asp-controller="GameEntries" asp-action="Index">Game Entries</a>
                    <a class="smb-login-nav-link" asp-area="" asp-controller="Login" asp-action="Logout">Logout</a>
                }
                <a class="smb-login-nav-link" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </nav>
    </header>
    <div class="container smb-page-shell">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/flatpickr.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/flatpickr@4.6.13/dist/l10n/hr.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
