@model GameEntry

@{
    ViewData["Title"] = "Delete Game Entry";
}

<h1>@ViewData["Title"]</h1>

<div class="card">
    <div class="card-body">
        <div class="mario-delete-summary">
            <p><strong>Game:</strong> @Model.Game?.Title</p>
            <p><strong>User:</strong> @Model.User?.UserName</p>
            <p><strong>Status:</strong> @Model.Status</p>
            <p><strong>Hours:</strong> @Model.HoursPlayed</p>
            <p><strong>Review Date:</strong> @Model.CreatedAt.ToString("g")</p>
        </div>

        <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="mario-actions">
            <button type="submit" class="btn btn-sm">Delete Entry</button>
        </form>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
