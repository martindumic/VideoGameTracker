@model GameEntryFormViewModel

@{
    ViewData["Title"] = "Edit Game Entry";
}

<h1>@ViewData["Title"]</h1>

@if (TempData["Success"] != null)
{
    <div class="login-alert home-alert login-alert-success" role="alert">@TempData["Success"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="login-alert home-alert login-alert-error" role="alert">@TempData["Error"]</div>
}

<div class="card">
    <div class="card-body">
        <form asp-action="Edit" asp-route-id="@Model.Id" method="post" class="mario-form">
            @await Html.PartialAsync("_GameEntryForm", Model)
            <div class="mario-actions">
                <button type="submit" class="btn btn-sm">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<div class="card mario-gallery-card-shell">
    <div class="card-body">
        <h2 class="mario-gallery-title">Game Gallery</h2>

        <form id="game-entry-dropzone"
              asp-action="UploadScreenshot"
              asp-controller="GameEntries"
              asp-route-id="@Model.Id"
              enctype="multipart/form-data"
              class="dropzone mario-dropzone">
            @Html.AntiForgeryToken()
            <div class="dz-message">
                Drop screenshots here or click to upload.
            </div>
        </form>

        <div id="game-entry-gallery" class="mario-gallery-region"></div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/dropzone@5.9.3/dist/min/dropzone.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/dropzone@5.9.3/dist/min/dropzone.min.js"></script>
    <script type="text/javascript">
        Dropzone.autoDiscover = false;

        (function () {
            const galleryRegion = "#game-entry-gallery";
            const listUrl = "@Url.Action("Screenshots", "GameEntries", new { id = Model.Id })";
            const token = document.querySelector("#game-entry-dropzone input[name='__RequestVerificationToken']").value;

            const loadGallery = () => {
                $(galleryRegion).load(listUrl);
            };

            const dropzone = new Dropzone("#game-entry-dropzone", {
                paramName: "file",
                maxFilesize: 5,
                acceptedFiles: ".jpg,.jpeg,.png,.webp",
                headers: { "RequestVerificationToken": token },
                params: { __RequestVerificationToken: token },
                init: function () {
                    this.on("success", function () {
                        loadGallery();
                    });
                }
            });

            $(document).on("click", ".mario-gallery-delete", function () {
                const deleteUrl = $(this).data("deleteUrl");
                if (!deleteUrl) return;

                $.ajax({
                    url: deleteUrl,
                    method: "POST",
                    headers: { "RequestVerificationToken": token },
                    data: { __RequestVerificationToken: token },
                    success: function () {
                        loadGallery();
                    }
                });
            });

            $(function () {
                loadGallery();
            });
        })();
    </script>
}
