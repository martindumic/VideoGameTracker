@model GameEntry

@{
    ViewData["Title"] = "Game Entry Details";
}

<h1>@ViewData["Title"]</h1>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <h5>Game</h5>
                <p>@Model.Game?.Title</p>
            </div>
            <div class="col-md-6">
                <h5>User</h5>
                <p>@Model.User?.UserName</p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <h5>Status</h5>
                <p><span class="badge bg-secondary">@Model.Status</span></p>
            </div>
            <div class="col-md-4">
                <h5>Hours Played</h5>
                <p>@Model.HoursPlayed</p>
            </div>
            <div class="col-md-4">
                <h5>Review Date</h5>
                <p>@Model.CreatedAt.ToString("g")</p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-12">
                <h5>Review</h5>
                <div class="mario-detail-box">
                    <div class="mario-detail-box-body">
                        <p><strong>Score:</strong> @(Model.ReviewScore.HasValue ? $"{Model.ReviewScore}/100" : "-")</p>
                        <p><strong>Comment:</strong> @(string.IsNullOrWhiteSpace(Model.ReviewComment) ? "No comment" : Model.ReviewComment)</p>
                    </div>
                </div>
            </div>
        </div>

        <div class="mario-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm">Edit</a>
            <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-sm">Delete</a>
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
