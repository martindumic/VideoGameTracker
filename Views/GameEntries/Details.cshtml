@model GameEntry

@{
    ViewData["Title"] = "Game Entry Details";
}

<h1>Game Entry</h1>

<div class="card">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-6">
                <h5>Game</h5>
                <p>
                    @if (Model.Game != null)
                    {
                        <a asp-controller="Games" asp-action="Details" asp-route-id="@Model.Game.Id">
                            @Model.Game.Title
                        </a>
                    }
                </p>
            </div>
            <div class="col-md-6">
                <h5>User</h5>
                <p>
                    @if (Model.User != null)
                    {
                        <a asp-controller="Users" asp-action="Details" asp-route-id="@Model.User.Id">
                            @Model.User.Username
                        </a>
                    }
                </p>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-4">
                <h5>Status</h5>
                <p><span class="badge bg-secondary">@Model.Status</span></p>
            </div>
            <div class="col-md-4">
                <h5>Hours Played</h5>
                <p>@Model.HoursPlayed</p>
            </div>
            <div class="col-md-4">
                <h5>Date Added</h5>
                <p>@Model.DateAdded.ToString("dd/MM/yyyy")</p>
            </div>
        </div>

        @if (Model.Review != null)
        {
            <div class="row mb-3">
                <div class="col-12">
                    <h5>Review</h5>
                    <div class="card bg-light">
                        <div class="card-body">
                            <p>
                                <strong>Score:</strong>
                                <span class="badge bg-warning">@Model.Review.Score/100</span>
                            </p>
                            <p>
                                <strong>Comment:</strong>
                                @Model.Review.Comment
                            </p>
                            <p>
                                <strong>Created:</strong>
                                @Model.Review.CreatedAt.ToString("dd/MM/yyyy")
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="mt-3">
    <a asp-controller="GameEntries" asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
