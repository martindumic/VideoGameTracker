@model GameEntryIndexViewModel

@{
    ViewData["Title"] = "Game Entries";
    ViewData["BodyClass"] = "page-mario page-game-entries";
}

<section class="mario-stage mario-stage-prose">
    <div class="mario-panel mario-panel-wide mario-panel-split">
        <div class="mario-panel-header">
            <div>
                <h1>@ViewData["Title"]</h1>
            </div>
            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a asp-action="Create" class="btn btn-sm">New Entry</a>
            }
        </div>

        @if (TempData["Success"] != null)
        {
            <div class="login-alert home-alert login-alert-success" role="alert">@TempData["Success"]</div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="login-alert home-alert login-alert-error" role="alert">@TempData["Error"]</div>
        }

        <div class="mario-panel-card">
            <div class="mario-search">
                <label for="game-entry-search" class="form-label">Search entries</label>
                <div class="mario-search-row">
                    <input id="game-entry-search" type="text" class="form-control mario-input js-entry-search" placeholder="Search games, users, comments..." data-search-url="@Url.Action("Search", "GameEntries")" />
                    <span class="mario-search-spinner" aria-hidden="true"></span>
                </div>
            </div>

            <div id="game-entry-list" class="mario-list-region">
                @await Html.PartialAsync("_GameEntryTable", Model.Entries)
            </div>
        </div>
    </div>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
