@{
    ViewData["Title"] = "Home";
    ViewData["BodyClass"] = "page-mario page-home";
    var user = (VideoGameTracker.Models.User)ViewBag.User;
    var games = (List<VideoGameTracker.Models.Game>)ViewBag.Games;
    var statuses = (List<VideoGameTracker.Models.GameStatus>)ViewBag.Statuses;
}

<section class="login-title-stage home-title-stage">
    <div class="login-title-lockup home-title-lockup">
        <img src="~/images/smb_logo.png" alt="Super Mario Bros inspired logo" class="login-logo-image" />
        <h1 class="login-app-title">VideoGameTracker</h1>
        <p class="login-subtitle">PLAYER DASHBOARD</p>
    </div>

    <div class="home-title-copy">
        <p class="home-title-line"><strong>Email:</strong> @user.Email</p>
        <p class="home-title-line"><strong>Member Since:</strong> @user.RegisteredAt.ToString("dd/MM/yyyy")</p>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="login-alert home-alert" role="alert">@TempData["Success"]</div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="login-alert home-alert" role="alert">@TempData["Error"]</div>
    }

    <div class="home-entry-form-wrap">
        <form method="post" asp-action="CreateGameEntry" asp-controller="Home" class="login-title-form home-title-form">
            <h2 class="home-form-title">CREATE GAME ENTRY</h2>

            <div class="login-field">
                <label for="gameId" class="login-field-label">GAME</label>
                <select class="login-title-input" id="gameId" name="gameId" required>
                    <option value="">SELECT A GAME...</option>
                    @foreach (var game in games)
                    {
                        <option value="@game.Id">@game.Title</option>
                    }
                </select>
            </div>

            <div class="login-field">
                <label for="status" class="login-field-label">STATUS</label>
                <select class="login-title-input" id="status" name="status" required>
                    <option value="">SELECT STATUS...</option>
                    @foreach (var status in statuses)
                    {
                        <option value="@status">@status</option>
                    }
                </select>
            </div>

            <div class="login-field">
                <label for="hoursPlayed" class="login-field-label">HOURS PLAYED</label>
                <input type="number" class="login-title-input" id="hoursPlayed" name="hoursPlayed" min="0" required>
            </div>

            <div class="login-field">
                <label for="score" class="login-field-label">REVIEW SCORE</label>
                <input type="number" class="login-title-input" id="score" name="score" min="1" max="100" required>
            </div>

            <div class="login-field">
                <label for="comment" class="login-field-label">REVIEW COMMENT</label>
                <textarea class="login-title-input home-textarea" id="comment" name="comment" rows="4" placeholder="WRITE YOUR REVIEW..."></textarea>
            </div>

            <button type="submit" class="login-title-button home-action-button">
                <span class="login-title-bullet" aria-hidden="true">●</span>
                <span>CREATE GAME ENTRY</span>
            </button>
        </form>
    </div>
</section>
